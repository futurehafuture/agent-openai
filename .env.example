# Copy to .env and fill in. The .env file is git-ignored and never committed.

# Required: your OpenAI API key. The app also lets you paste this in Settings,
# but an env var here takes precedence and is the recommended approach.
OPENAI_API_KEY=sk-...

# Optional overrides (all have sensible defaults; usually managed from the in-app Settings panel)
# LUMEN_MODEL=gpt-4.1
# LUMEN_WORKSPACE=~/Lumen
# LUMEN_HOST=127.0.0.1
# LUMEN_PORT=8765
# LUMEN_MAX_TURNS=24
# LUMEN_LOG_LEVEL=INFO
# LUMEN_ENABLE_TRACING=0
